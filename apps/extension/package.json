{
  "name": "@tabstow/extension",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build -b chrome && bun run verify:build",
    "zip": "wxt zip -b chrome",
    "typecheck": "wxt prepare && tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "verify:build": "bun scripts/verify-built-extension.ts",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@tabstow/core": "workspace:*",
    "@wxt-dev/module-react": "1.2.2",
    "dexie": "4.4.4",
    "lucide-react": "1.23.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "wxt": "0.20.27"
  },
  "devDependencies": {
    "@types/chrome": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "latest"
  }
}
